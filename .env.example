# ==============================================================================
# IntelliGraph-RAG Environment Configuration Example
# ==============================================================================
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit the '.env' file to your public repository!
# ==============================================================================

# 1. LLM API Configurations
# Your DeepSeek API Key (Required for conversation & metadata extraction)
# Retrieve from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Preferred Model Name (Defaults to deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat

# 2. Local Storage Paths (Optional - defaults to ./rag_storage)
# RAG_PERSIST_DIR=./rag_storage
